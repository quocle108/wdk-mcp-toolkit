{
  "name": "@tetherto/wdk-mcp-toolkit",
  "version": "1.0.0-beta.1",
  "description": "Model Context Protocol (MCP) server for Tether Wallet Development Kit (WDK). Provides unified blockchain operations through the MCP.",
  "keywords": [
    "wdk",
    "mcp",
    "wallet",
    "blockchain",
    "model-context-protocol"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git://github.com/tetherto/wdk-mcp-toolkit.git"
  },
  "main": "index.js",
  "type": "module",
  "types": "./types",
  "files": [
    "bin/",
    "index.js",
    "src/",
    "types/"
  ],
  "scripts": {
    "build:types": "tsc",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "setup": "node bin/index.js setup"
  },
  "bin": {
    "wdk-mcp-toolkit": "./bin/index.js"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./index.js"
    },
    "./package": {
      "default": "./package.json"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "standard": {
    "ignore": [
      "types/**/*.d.ts",
      "tests/**/*.js"
    ]
  },
  "dependencies": {
    "@inquirer/prompts": "7.10.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@tetherto/wdk": "1.0.0-beta.10",
    "@tetherto/wdk-indexer-http": "github:tetherto/wdk-indexer-http#fbde10bae408d546647ad6e6b8dcfaf8f0e6f103",
    "@tetherto/wdk-pricing-bitfinex-http": "1.0.0-beta.3",
    "@tetherto/wdk-wallet": "1.0.0-beta.9",
    "bip39": "3.1.0",
    "picocolors": "1.1.1",
    "zod": "3.25.76"
  },
  "overrides": {
    "axios": "1.16.1"
  },
  "devDependencies": {
    "@tetherto/wdk-wallet-btc": "1.0.0-beta.9",
    "@tetherto/wdk-wallet-evm": "1.0.0-beta.13",
    "cross-env": "7.0.3",
    "jest": "30.4.2",
    "standard": "17.1.2",
    "typescript": "5.8.3"
  }
}
